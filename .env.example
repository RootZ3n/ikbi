# ══════════════════════════════════════════════════════════════════════
# ikbi environment configuration
# Copy to .env and fill in the values you need.
# All knobs are IKBI_* prefixed. See src/core/config.ts for the canonical
# reference; module-specific knobs live in src/modules/<module>/config.ts.
# ══════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────

# TCP port (default 18796)
# IKBI_PORT=18796

# Host/interface to bind (default 127.0.0.1; Tailscale works on loopback)
# IKBI_BIND_HOST=127.0.0.1

# Allow binding a non-loopback / public interface (default false)
# IKBI_ALLOW_PUBLIC_BIND=false

# ── Runtime ───────────────────────────────────────────────────────────

# Runtime environment (falls back to NODE_ENV; default "development")
# IKBI_ENV=development

# Log level: trace, debug, info, warn, error, fatal (default "info")
# IKBI_LOG_LEVEL=info

# Root directory for all runtime state (default ~/.ikbi/state)
# IKBI_STATE_ROOT=~/.ikbi/state

# ── Security / Trust keys (REQUIRED FOR PRODUCTION) ───────────────────
# Without these set, ikbi refuses to start (or set IKBI_ALLOW_INSECURE_DEV_KEYS=true for dev).
#
# SECURITY: the four secret keys below are intentionally COMMENTED OUT. ikbi REFUSES to load
# them from a *project-directory* .env (so a target repo can never carry trust credentials).
# Put real values in ~/.ikbi/env or the ikbi install-root .env, then uncomment them there:

# Pepper for token-hash KDF (set a unique random value in production)
# IKBI_IDENTITY_TOKEN_SALT=<a strong random salt>

# HMAC key for trust-state integrity (set a unique random value in production)
# IKBI_TRUST_HMAC_KEY=<a strong random key>

# Allow starting on the insecure built-in dev defaults (NEVER set in production)
# IKBI_ALLOW_INSECURE_DEV_KEYS=true

# Master switch — builds are disabled until this is on (safe in a project .env)
# IKBI_WORKER_MODEL_ENABLED=true

# ── Identity / authentication ─────────────────────────────────────────

# Bootstrap operator token (plaintext; hashed at load — never stored raw).
# Secret — keep in ~/.ikbi/env or the install-root .env, not a project .env.
# IKBI_OPERATOR_TOKEN=<32+ char token>

# Agent id for the bootstrapped operator (default "operator")
# IKBI_OPERATOR_AGENT_ID=operator

# Bootstrap worker token (required for the worker-model orchestrator).
# Secret — keep in ~/.ikbi/env or the install-root .env, not a project .env.
# IKBI_WORKER_TOKEN=<32+ char token>

# Agent id for the bootstrapped worker (default "worker")
# IKBI_WORKER_AGENT_ID=worker

# Worker trust tier — a FLOOR, not a ceiling (default "trusted")
# IKBI_WORKER_TRUST_TIER=trusted

# Path to the agents JSON registry (default <stateRoot>/agents.json)
# IKBI_IDENTITY_REGISTRY=

# ── Model providers ───────────────────────────────────────────────────

# Default model ids
# IKBI_MODEL_DRIVER=mimo-v2.5
# IKBI_MODEL_BUILDER=                  (falls through to driver when unset)
# IKBI_MODEL_CRITIC=deepseek-v4-pro

# Comma-separated competitive-model list (optional head-to-head)
# IKBI_COMPETITIVE_MODELS=model-a,model-b

# MiMo API (OpenAI-shaped, keyless + api-key header)
# IKBI_MIMO_API_KEY=
# IKBI_MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# OpenRouter API
# IKBI_OPENROUTER_API_KEY=
# IKBI_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# IKBI_OPENROUTER_REFERER=
# IKBI_OPENROUTER_TITLE=

# DeepSeek API (OpenAI-compatible)
# IKBI_DEEPSEEK_API_KEY=
# IKBI_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# MiniMax API (OpenAI-compatible)
# IKBI_MINIMAX_API_KEY=
# IKBI_MINIMAX_BASE_URL=https://api.minimax.chat/v1

# OpenAI API
# IKBI_OPENAI_API_KEY=
# IKBI_OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API
# IKBI_ANTHROPIC_API_KEY=
# IKBI_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Ollama (local, no key needed)
# IKBI_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# Google/Gemini API (OpenAI-compatible proxy or direct)
# IKBI_GOOGLE_API_KEY=
# IKBI_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Groq API (OpenAI-compatible)
# IKBI_GROQ_API_KEY=
# IKBI_GROQ_BASE_URL=https://api.groq.com/openai/v1

# Mistral API (OpenAI-compatible)
# IKBI_MISTRAL_API_KEY=
# IKBI_MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Together API (OpenAI-compatible)
# IKBI_TOGETHER_API_KEY=
# IKBI_TOGETHER_BASE_URL=https://api.together.xyz/v1

# Provider roster file (JSON model table; default <stateRoot>/providers.json)
# IKBI_PROVIDER_CONFIG=

# Per-request timeout (default 60000 ms)
# IKBI_PROVIDER_TIMEOUT_MS=60000

# Same-route retry for transient failures (5xx / 429 / network / timeout). Honors a
# server Retry-After header. Set MAX_RETRIES=0 to disable.
# IKBI_PROVIDER_MAX_RETRIES=2
# IKBI_PROVIDER_RETRY_BASE_MS=300
# IKBI_PROVIDER_RETRY_MAX_MS=5000

# ── Circuit breaker ───────────────────────────────────────────────────

# IKBI_CIRCUIT_FAILURE_THRESHOLD=5
# IKBI_CIRCUIT_COOLDOWN_MS=30000
# IKBI_CIRCUIT_HALF_OPEN_TRIALS=1

# ── Verification / retrieval modes ────────────────────────────────────

# Verification: "ladder" (hardened, production default) or "legacy"
# IKBI_VERIFY=ladder

# Retrieval: "index" (hardened, production default) or "legacy"
# IKBI_RETRIEVAL=index

# Custom check commands (JSON array; overrides built-in checks)
# IKBI_CHECKS=[{"name":"check","command":"pnpm","args":["test"]}]

# ── Trust system ──────────────────────────────────────────────────────

# IKBI_TRUST_DIR=<stateRoot>/trust
# IKBI_TRUST_PROMOTE_STREAK=20
# IKBI_TRUST_DEMOTE_STREAK=3
# IKBI_TRUST_PROMOTE_MIN_DISTINCT_OPS=2

# ── Receipt store ─────────────────────────────────────────────────────

# IKBI_RECEIPT_DIR=<stateRoot>/receipts
# IKBI_RECEIPT_RETENTION_DAYS=30

# ── Injection scanner ─────────────────────────────────────────────────

# IKBI_INJECTION_MAX_SCAN_BYTES=1000000
# IKBI_INJECTION_MAX_CONTENT_BYTES=5000000
# IKBI_INJECTION_EXCERPT_MAX=160

# ── Substrate (atomic writes + locking) ───────────────────────────────

# IKBI_LOCK_TIMEOUT_MS=10000
# IKBI_LOCK_STALE_MS=30000
# IKBI_FSYNC=true

# ── Event bus ─────────────────────────────────────────────────────────

# IKBI_EVENT_MAX_QUEUE=1000

# ── Workspace ─────────────────────────────────────────────────────────

# IKBI_WORKSPACE_ROOT=<stateRoot>/workspaces
# IKBI_WORKSPACE_MAX=32

# ── Governed execution (verifier / terminal command allowlist) ────────

# Binaries the verifier and terminal tool may run. ADDITIVE — your entries EXTEND the
# built-in defaults (git, ls, head, tail, wc, find, grep, echo, npm, npx, pnpm, yarn).
# Add toolchains for non-JS repos, e.g.:
# IKBI_GOVERNED_EXEC_ALLOWLIST=cargo,go,python3,make
# IKBI_GOVERNED_EXEC_ENABLED=true

# ── Network egress ────────────────────────────────────────────────────

# Egress host allowlist. The guard is default-deny but ships NON-EMPTY (provider API hosts
# + developer.mozilla.org + stackoverflow.com). NOTE: setting this REPLACES the defaults —
# include your provider host(s) or model calls fail closed.
# IKBI_EGRESS_ALLOWLIST=api.openai.com,developer.mozilla.org

# Loopback endpoints a build may reach (needed for local models), ip:port form:
# IKBI_EGRESS_ALLOW_LOCAL=127.0.0.1:11434

# ── HTTP /chat ────────────────────────────────────────────────────────

# Bearer token for POST /chat endpoint (REQUIRED to enable HTTP chat)
# IKBI_CHAT_TOKEN=

# ── External integrations ─────────────────────────────────────────────

# Path to the lab capability registry JSON (used by capability-registry module)
# LAB_CAPABILITY_REGISTRY=/path/to/lab-capability/registry.json

# OPTIONAL labmem integration (lab-wide shared memory). ikbi is fully functional WITHOUT it —
# when labmem's built code is absent the recall surface degrades gracefully (LabmemUnavailable).
# Point this at a BUILT labmem checkout to enable shared/lab memory recall.
# LABMEM_ROOT=/path/to/lab-memory/labmem
