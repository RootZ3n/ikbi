# Dependencies
node_modules/

# Build output (ikbi's own dist only — anchored so the vendored, prebuilt
# vendor/velum-ai/dist is still committed and travels with a fresh clone).
/dist/

# Runtime state (never commit)
state/
# Legacy/alternate lab-memory location (default now lives under state/; belt-and-suspenders)
.ikbi/

# Environment / secrets
.env
.env.*
!.env.example

# Logs
*.log

# Local, per-user Claude Code settings (not shared)
.claude/settings.local.json

# Proving-ground fixtures (temp repos with node_modules); the isolated `state/` roots are already
# covered by the unanchored `state/` rule above. The small .md/.jsonl evidence stays committable.
reports/proving-ground/*/fixtures/

# Editor / OS cruft
.DS_Store
*.swp
.idea/
.vscode/
memory-governor/
