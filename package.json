{
  "name": "ikbi",
  "version": "0.1.0-rc.1",
  "description": "ikbi (Choctaw: \"to build\") — the build/repair engine for a lab of agents. A localhost/Tailscale-reachable system service.",
  "type": "module",
  "author": "Jeffrey Miller",
  "license": "MIT",
  "author": "RootZ3n <rootz3n@proton.me>",
  "repository": {
    "type": "git",
    "url": "https://github.com/RootZ3n/ikbi.git"
  },
  "homepage": "https://github.com/RootZ3n/ikbi#readme",
  "bugs": {
    "url": "https://github.com/RootZ3n/ikbi/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RootZ3n/ikbi.git"
  },
  "homepage": "https://github.com/RootZ3n/ikbi#readme",
  "keywords": [
    "build-engine",
    "agent-orchestration",
    "repair-engine",
    "code-generation",
    "verification",
    "governance",
    "ai-agent",
    "developer-tools"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "ikbi": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.map",
    "!dist/acceptance/**",
    "deploy/",
    ".env.example",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SUPPORT.md",
    "SECURITY.md",
    "docs/INSTALL.md",
    "docs/KNOWN-LIMITATIONS.md",
    "docs/RC1-RELEASE.md",
    "docs/MANUAL.md",
    "vendor/velum-ai/",
    "!vendor/velum-ai/src/**",
    "!vendor/velum-ai/tests/**",
    "!vendor/velum-ai/examples/**",
    "!vendor/velum-ai/**/*.map"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "sh -c 'IKBI_STATE_ROOT=$(mktemp -d /tmp/ikbi-test-state.XXXXXX) env -u IKBI_OPERATOR_TOKEN -u IKBI_WORKER_TOKEN IKBI_ALLOW_INSECURE_DEV_KEYS=true node --import tsx --test \"src/**/*.test.ts\"'",
    "public:smoke": "bash scripts/public-smoke.sh"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "velum-ai": "file:./vendor/velum-ai"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3"
  }
}
